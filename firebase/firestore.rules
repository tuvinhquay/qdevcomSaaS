rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserProfile() {
      return isSignedIn() && exists(userDocPath());
    }

    function userData() {
      return get(userDocPath()).data;
    }

    function currentCompanyId() {
      return hasUserProfile() ? userData().companyId : null;
    }

    function currentRole() {
      return hasUserProfile() ? userData().role : null;
    }

    function isCompanyMember(companyId) {
      return hasUserProfile() && currentCompanyId() == companyId;
    }

    function isOwner() {
      return currentRole() == 'owner';
    }

    function isAdmin() {
      return currentRole() == 'admin';
    }

    function isManager() {
      return currentRole() == 'manager';
    }

    function isStaff() {
      return currentRole() == 'staff';
    }

    function isGuest() {
      return currentRole() == 'guest';
    }

    function isOwnerOrAdmin() {
      return isOwner() || isAdmin();
    }

    function moduleEnabled(companyId, moduleFlag) {
      return exists(/databases/$(database)/documents/companies/$(companyId)/modules/core) &&
        get(/databases/$(database)/documents/companies/$(companyId)/modules/core).data[moduleFlag] == true;
    }

    function canReadChats(companyId) {
      return isCompanyMember(companyId) && moduleEnabled(companyId, 'chatEnabled');
    }

    function canWriteChats(companyId) {
      return canReadChats(companyId) && !isGuest();
    }

    function canReadProduction(companyId) {
      return isCompanyMember(companyId) && moduleEnabled(companyId, 'productionEnabled');
    }

    function canWriteProduction(companyId) {
      return canReadProduction(companyId) && (isOwnerOrAdmin() || isManager());
    }

    function canReadWarehouse(companyId) {
      return isCompanyMember(companyId) && moduleEnabled(companyId, 'warehouseEnabled');
    }

    function canWriteWarehouse(companyId) {
      return canReadWarehouse(companyId) && (isOwnerOrAdmin() || isStaff());
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        (isOwnerOrAdmin() && resource.data.companyId == currentCompanyId())
      );

      allow create: if isSignedIn() && request.auth.uid == userId;

      allow update: if isSignedIn() && (
        request.auth.uid == userId ||
        (
          isOwnerOrAdmin() &&
          resource.data.companyId == currentCompanyId() &&
          request.resource.data.companyId == currentCompanyId()
        )
      );

      allow delete: if false;
    }

    match /companies/{companyId} {
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow read: if isCompanyMember(companyId);
      allow update, delete: if isCompanyMember(companyId) && isOwnerOrAdmin();

      match /members/{memberId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isCompanyMember(companyId) && isOwnerOrAdmin();
      }

      match /modules/{moduleId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isCompanyMember(companyId) && isOwnerOrAdmin();
      }

      match /workOrders/{docId} {
        allow read: if canReadProduction(companyId);
        allow write: if canWriteProduction(companyId);
      }

      match /productionOrders/{docId} {
        allow read: if canReadProduction(companyId);
        allow write: if canWriteProduction(companyId);
      }

      match /inventory/{docId} {
        allow read: if canReadWarehouse(companyId);
        allow write: if canWriteWarehouse(companyId);
      }

      match /chats/{docId} {
        allow read: if canReadChats(companyId);
        allow write: if canWriteChats(companyId);
      }
    }
  }
}
